# =============================================================================
# .env.example
# Copy this to .env and fill in your values before running the application.
# NEVER commit your real .env file to version control.
# =============================================================================

# --- Application ---
APP_NAME="Lockdown Flash-Sale API"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# --- MySQL (running natively on your host machine) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=lockdown_db

# SQLAlchemy connection pool tuning
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis (Docker container — see docker-compose.yml) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password_here  # uncomment if you set requirepass

# Seat lock TTL — how long a seat is "held" during payment processing (seconds)
SEAT_LOCK_TTL_SECONDS=300

# Rate limiting — max booking requests per user per window
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# --- RabbitMQ (Docker container — see docker-compose.yml) ---
RABBITMQ_USER=lockdown
RABBITMQ_PASS=lockdown_secret
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=lockdown_vhost

# Celery result backend Redis DB (use a different DB index to avoid key collisions)
CELERY_RESULT_BACKEND_DB=1

# --- Payment simulation (replace with real gateway config) ---
PAYMENT_SIMULATION_DELAY=3
