# Normalize line endings to LF in the repository.
# Checked-out files will use the OS native endings.
* text=auto

# Force LF for all source files
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.env*  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf

# Binary files — never mangle
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
