# =============================================================================
# .gitignore — Lockdown Flash-Sale API
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
share/python-wheels/
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env.bak
env.bak/

# ---------------------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/

# ---------------------------------------------------------------------------
# Pytest / Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
nosetests.xml
test-results/

# ---------------------------------------------------------------------------
# MyPy / Pyright / Ruff
# ---------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
pyrightconfig.json

# ---------------------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# ---------------------------------------------------------------------------
# OS artifacts
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.log
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
celerybeat-schedule
celerybeat.pid
celery_tasks.db

# ---------------------------------------------------------------------------
# Database dumps / local data
# ---------------------------------------------------------------------------
*.sqlite3
*.db
*.sql
dumps/

# ---------------------------------------------------------------------------
# Alembic (migration tool — versions dir is committed, but local state is not)
# ---------------------------------------------------------------------------
alembic/versions/__pycache__/

# ---------------------------------------------------------------------------
# Jupyter / IPython
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.bak
*.tmp
*.swp
*.swo
